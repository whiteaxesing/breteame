# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.claude/

# Panfletos generados (regenerables con scripts/generar-panfletos.mjs)
/panfletos/

# Pitch deck generado (regenerable con scripts/capturas-pitch.mjs + deck-pdf.mjs)
/presentacion/shots/
/presentacion/preview/
/presentacion/*.pdf
