# Supabase — copiá este archivo a .env.local y completá con los valores de tu proyecto.
# Settings → API en el dashboard de Supabase.

# URL del proyecto (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key (segura para el navegador; la protección real es RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SOLO para scripts/seed-users.mjs en tu máquina.
# NUNCA la expongas en el cliente ni la subas al repo.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — API key para correos transaccionales mandados desde el código
# (distinto del SMTP de Supabase, que se configura en su dashboard).
RESEND_API_KEY=

# Google OAuth Client ID (Web application) — el mismo que está cargado en
# Supabase → Authentication → Providers → Google. Se usa en el cliente para
# el botón "Continuar con Google" (Google Identity Services), que llama a
# supabase.auth.signInWithIdToken en vez del redirect clásico — así el
# consent screen de Google muestra tu dominio y no el de Supabase.
# Acordate de agregar tu dominio (y localhost para dev) en "Authorized
# JavaScript origins" del OAuth Client en Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OpenAI — moderación automática de fotos (endpoint /v1/moderations, gratis).
# Si se deja vacío, las fotos caen a revisión manual del admin (no se rompe nada).
OPENAI_API_KEY=
