# Supabase — copiá este archivo a .env.local y completá con los valores de tu proyecto.
# Settings → API en el dashboard de Supabase.

# URL del proyecto (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key (segura para el navegador; la protección real es RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SOLO para scripts/seed-users.mjs en tu máquina.
# NUNCA la expongas en el cliente ni la subas al repo.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — API key para correos transaccionales mandados desde el código
# (distinto del SMTP de Supabase, que se configura en su dashboard).
RESEND_API_KEY=
